{
  "name": "optimizely-nextjs-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "opti:login": "npx @optimizely/cms-cli@latest login",
    "opti:push": "npx @optimizely/cms-cli@latest config push optimizely.config.mjs",
    "seed": "npx tsx scripts/seed-content.ts",
    "seed:nav": "npx tsx scripts/seed-nav.ts",
    "seed:faqs": "npx tsx scripts/seed-faqs.ts",
    "seed:modeling": "npx tsx scripts/seed-modeling.ts",
    "seed:all": "npm run opti:push && npm run seed && npm run seed:nav && npm run seed:modeling && npm run seed:faqs && npm run webhook:register",
    "cleanup:types": "npx tsx scripts/cleanup-types.ts",
    "webhook:register": "node scripts/register-webhook.mjs"
  },
  "dependencies": {
    "@optimizely/cms-sdk": "^2.0.0",
    "@optimizely/optimizely-sdk": "^6.4.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@optimizely/cms-cli": "^1.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
