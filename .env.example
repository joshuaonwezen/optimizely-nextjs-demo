# Optimizely Graph
OPTIMIZELY_GRAPH_SINGLE_KEY=
OPTIMIZELY_GRAPH_GATEWAY=https://cg.optimizely.com/content/v2

# Optimizely CMS
OPTIMIZELY_CMS_URL=
NEXT_PUBLIC_OPTIMIZELY_CMS_URL=

# Optimizely Graph content sync auth (used by seed-referrals.ts)
OPTIMIZELY_APP_KEY=
OPTIMIZELY_APP_SECRET=

# Optimizely CMS Management API (used by seed scripts)
OPTIMIZELY_CMS_CLIENT_ID=
OPTIMIZELY_CMS_CLIENT_SECRET=
OPTIMIZELY_ROOT_CONTAINER=       # key of the root CMS container — create it in the CMS UI, then copy its key here

# Security — change these before deploying
OPTIMIZELY_PREVIEW_SECRET=
OPTIMIZELY_REVALIDATE_SECRET=

# Optimizely Feature Experimentation
OPTIMIZELY_FX_SDK_KEY=

# Optimizely Data Platform (ODP) — for direct segment-based personalization
NEXT_PUBLIC_OPTIMIZELY_ODP_TRACKER_ID=   # public tracker ID for the client-side tag
OPTIMIZELY_ODP_API_KEY=                  # same value — used server-side for segment queries
OPTIMIZELY_ODP_API_HOST=https://api.zaius.com

# Seed scripts only — pass inline rather than committing to .env.local
# OPTIMIZELY_FX_API_TOKEN=
# OPTIMIZELY_FX_PROJECT_ID=
